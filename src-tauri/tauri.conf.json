{
  "productName": "Moscad",
  "version": "1.0.0",
  "identifier": "com.lbjlaq.antigravity",
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": ["icons/32x32.png", "icons/128x128.png", "icons/128x128@2x.png", "icons/icon.icns", "icons/icon.ico"],
    "externalBin": ["binaries/sidecar"]
  },
  "app": {
    "windows": [
      {
        "title": "Moscad",
        "width": 800,
        "height": 600,
        "fullscreen": false,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "plugins": {
    "shell": {
      "sidecar": true
    }
  }
}
